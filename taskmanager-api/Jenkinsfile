pipeline {
    agent any

    environment {
        IMAGE_NAME     = 'taskmanager-api'
        IMAGE_TAG      = "${env.BUILD_NUMBER}"
        SONAR_HOST_URL = 'http://sonarqube:9000'
        SONAR_TOKEN    = credentials('sonar-token')
        CONTAINER_NAME = 'taskmanager-staging'
        PROD_CONTAINER = 'taskmanager-prod'
    }

    stages {

        // ── STAGE 1: BUILD ──────────────────────────
        stage('Build') {
            steps {
                echo "=== STAGE 1: BUILD ==="
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} -t ${IMAGE_NAME}:latest ."
                sh "docker images ${IMAGE_NAME}"
            }
            post {
                success { echo "Image built: ${IMAGE_NAME}:${IMAGE_TAG}" }
                failure { error "Build failed" }
            }
        }

        // ── STAGE 2: TEST ───────────────────────────
        stage('Test') {
            steps {
                echo "=== STAGE 2: TEST ==="
                sh """
                    docker run --rm \
                        --name taskmanager-test \
                        -v \$(pwd)/coverage:/app/coverage \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        sh -c "npm install --include=dev && npm run test:ci"
                """
            }
            post {
                success { echo "All tests passed" }
                failure  { error "Tests failed — pipeline aborted" }
            }
        }

        // ── STAGE 3: CODE QUALITY ───────────────────
        stage('Code Quality') {
            steps {
                echo "=== STAGE 3: CODE QUALITY ==="
                sh """
                    docker run --rm \
                        --network taskmanager-net \
                        -v \$(pwd):/usr/src \
                        -e SONAR_HOST_URL=${SONAR_HOST_URL} \
                        -e SONAR_TOKEN=${SONAR_TOKEN} \
                        sonarsource/sonar-scanner-cli:latest \
                        sonar-scanner \
                            -Dsonar.projectKey=taskmanager-api \
                            -Dsonar.sources=src \
                            -Dsonar.tests=tests \
                            -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info \
                            -Dsonar.host.url=${SONAR_HOST_URL} \
                            -Dsonar.login=${SONAR_TOKEN}
                """
            }
            post {
                success { echo "Quality gate passed" }
                failure  { error "Quality gate failed" }
            }
        }

        // ── STAGE 4: SECURITY ───────────────────────
        stage('Security') {
            steps {
                echo "=== STAGE 4: SECURITY ==="
                echo "--- npm audit ---"
                sh """
                    docker run --rm \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        sh -c "npm install --include=dev && npm audit --audit-level=high || true"
                """
                echo "--- Trivy image scan ---"
                sh """
                    docker run --rm \
                        -v /var/run/docker.sock:/var/run/docker.sock \
                        -v trivy-cache:/root/.cache \
                        aquasec/trivy:latest image \
                        --exit-code 0 \
                        --severity LOW,MEDIUM,HIGH,CRITICAL \
                        --format table \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                """
            }
            post {
                success { echo "Security scan complete" }
                failure  { echo "Security issues found — review output above" }
            }
        }

        // ── STAGE 5: DEPLOY (Staging) ───────────────
        stage('Deploy') {
            steps {
                echo "=== STAGE 5: DEPLOY TO STAGING ==="
                sh "docker stop ${CONTAINER_NAME} || true"
                sh "docker rm   ${CONTAINER_NAME} || true"
                sh """
                    docker run -d \
                        --name ${CONTAINER_NAME} \
                        --network taskmanager-net \
                        -p 3000:3000 \
                        -e NODE_ENV=staging \
                        -e JWT_SECRET=staging-secret-key \
                        -e DB_PATH=/app/data/taskmanager.db \
                        -v taskmanager-staging-data:/app/data \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                """
                sleep(time: 8, unit: 'SECONDS')
                sh "docker exec ${CONTAINER_NAME} wget -qO- http://localhost:3000/health || exit 1"
                echo "Staging health check passed"
            }
            post {
                success { echo "Deployed to staging on port 3000" }
                failure  { error "Staging deployment failed" }
            }
        }

        // ── STAGE 6: RELEASE (Production) ──────────
        stage('Release') {
            steps {
                echo "=== STAGE 6: RELEASE TO PRODUCTION ==="
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:prod-${IMAGE_TAG}"
                sh "docker stop ${PROD_CONTAINER} || true"
                sh "docker rm   ${PROD_CONTAINER} || true"
                sh """
                    docker run -d \
                        --name ${PROD_CONTAINER} \
                        --network taskmanager-net \
                        -p 3001:3000 \
                        -e NODE_ENV=production \
                        -e JWT_SECRET=prod-secret-key-change-me \
                        -e DB_PATH=/app/data/taskmanager.db \
                        -v taskmanager-prod-data:/app/data \
                        ${IMAGE_NAME}:prod-${IMAGE_TAG}
                """
                sleep(time: 8, unit: 'SECONDS')
                sh "docker exec ${PROD_CONTAINER} wget -qO- http://localhost:3000/health || exit 1"
                echo "Production health check passed on port 3001"
            }
            post {
                success { echo "Released prod-${IMAGE_TAG} to production" }
                failure  { error "Production release failed" }
            }
        }

        // ── STAGE 7: MONITORING ─────────────────────
        stage('Monitoring') {
            steps {
                echo "=== STAGE 7: MONITORING ==="
                sh """
                    docker run --rm \
                        --network taskmanager-net \
                        curlimages/curl:latest \
                        curl -sf http://${PROD_CONTAINER}:3000/metrics | grep http_requests_total
                """
                sh """
                    docker run --rm \
                        --network taskmanager-net \
                        curlimages/curl:latest \
                        curl -sf http://${PROD_CONTAINER}:3000/health
                """
                echo "Prometheus metrics endpoint verified"
                echo "Grafana dashboard: http://localhost:3002"
                echo "Prometheus UI:     http://localhost:9090"
            }
            post {
                success { echo "Monitoring verified — metrics flowing to Prometheus" }
                failure  { echo "Monitoring check failed — check container logs" }
            }
        }
    }

    post {
        always {
            echo "Pipeline complete. Build #${env.BUILD_NUMBER}"
            sh "docker ps --filter name=taskmanager"
        }
        success {
            echo "ALL STAGES PASSED — app running on :3001 (prod) and :3000 (staging)"
        }
        failure {
            echo "PIPELINE FAILED — check stage logs above"
        }
    }
}
